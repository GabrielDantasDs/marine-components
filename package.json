{
	"name": "marine-components",
	"version": "0.1.0",
	"description": "This is react component library.",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rollup -c",
		"prepublishOnly": "npm run build",
		"dev": "rollup -c -w",
		"test": "jest --watchAll --verbose",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepare": "husky",
		"lint": "eslint './src/**/*.{ts,tsx}' --fix"
	},
	"jest": {
		"testEnvironment": "jsdom",
		"transform": {
			"^.+\\.(ts|tsx)$": [
				"ts-jest",
				{
					"tsconfig": "<rootDir>/tsconfig.jest.json"
				}
			]
		},
		"moduleFileExtensions": [
			"ts",
			"tsx",
			"js",
			"jsx"
		],
		"moduleNameMappper": {
			"styled-components": "<rootDir>/node_modules/styled-components"
		}
	},
	"babel": {
		"presets": [
			"@babel/preset-env",
			"@babel/preset-react",
			"@babel/preset-typescript"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/GabrielDantasDs/marine-components.git"
	},
	"author": "GabrielDantasDs",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/GabrielDantasDs/marine-components/issues"
	},
	"homepage": "https://github.com/GabrielDantasDs/marine-components#readme",
	"devDependencies": {
		"@babel/preset-env": "^7.29.5",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/addon-docs": "^10.4.0",
		"@storybook/addon-mcp": "^0.6.0",
		"@storybook/addon-vitest": "^10.4.0",
		"@storybook/react-vite": "^10.4.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/jest": "^30.0.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6",
		"eslint": "^10.4.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"jiti": "^2.7.0",
		"playwright": "^1.60.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"rollup-plugin-dts": "^6.4.1",
		"rollup-plugin-postcss": "^4.0.2",
		"storybook": "^10.4.0",
		"styled-components": "^6.4.1",
		"ts-jest": "^29.4.9",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"react": ">=19.2.6",
		"styled-components": "^6.4.1"
	}
}
